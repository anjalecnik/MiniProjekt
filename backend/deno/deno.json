{
  "name": "health-api-deno",
  "version": "1.0.0",
  "description": "Health diary API backend using Deno + Hono",
  "imports": {
    "hono": "https://deno.land/x/hono@v3.12.0/mod.ts",
    "hono/middleware": "https://deno.land/x/hono@v3.12.0/middleware.ts",
    "sqlite": "https://deno.land/x/sqlite@v3.8/mod.ts"
  },
  "tasks": {
    "start": "deno run --allow-net --allow-read --allow-write main.ts",
    "dev": "deno run --allow-net --allow-read --allow-write --watch main.ts"
  },
  "lint": {
    "include": ["./"]
  },
  "fmt": {
    "semiColons": true,
    "singleQuote": false
  }
}
