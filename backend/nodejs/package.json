{
  "name": "health-api-nodejs",
  "version": "1.0.0",
  "description": "Health diary API backend using Node.js + Fastify",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --detectOpenHandles --testPathPattern=tests/",
    "test:perf": "k6 run ../../tests/k6-performance.js"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {}
  },
  "keywords": [
    "health",
    "api",
    "fastify",
    "pwa"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "better-sqlite3": "^12.10.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "supertest": "^7.2.2"
  }
}
